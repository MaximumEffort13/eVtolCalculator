@page "/inverterdesign"
@inject IAuthenticationService AuthService
@inject IInverterEndpoints InverterEndpoints

<EditForm Model="@model" OnValidSubmit="@OnValidSubmit">
    <DataAnnotationsValidator />
    <div class="container-fluid">
        <h4>Inverter Design:</h4>
        <div class="row row-cols-3">
            <div class="col g-3">
                <div class="form-floating mb-3">
                    <InputText id="inverterName" class="form-control" @bind-Value="model.Name" placeholder="Axial Flux M003" />
                    <ValidationMessage For=@(() => model.Name) />
                    <label for="inverterName">Name of Inverter:</label>
                </div>
                <div class="form-floating mb-3">
                    <InputNumber id="inverterVoltage" class="form-control" @bind-Value="model.VoltageRating_V" placeholder="50" />
                    <ValidationMessage For=@(() => model.VoltageRating_V) />
                    <label for="inverterVoltage">Inverter Voltage (V)</label>
                </div>
                <div class="form-floating mb-3">
                    <InputNumber id="inverterCurrent" class="form-control" @bind-Value="model.CurrentRating_A" placeholder="15" />
                    <ValidationMessage For=@(() => model.CurrentRating_A) />
                    <label for="motorCurrent">Inverter Current (A)</label>
                </div>
                <div class="form-floating mb-3">
                    <InputNumber id="motorWeight" class="form-control" @bind-Value="model.Weight_kg" placeholder="30" />
                    <ValidationMessage For=@(() => model.Weight_kg) />
                    <label for="motorWeight">Inverter Weight (kg): </label>
                </div>
            </div>
        </div>
    </div>
    <div class="row row-cols-6">
        <div class="col"></div>
        <div class="col"></div>
        <div class="col"></div>
        <div class="col"></div>
        <div class="col"></div>
        <div class="col">
            <Button Type="ButtonType.Submit" Color="ButtonColor.Success"><Icon Name="IconName.Check" @onclick="OnValidSubmit" />Submit</Button>
        </div>
    </div>
    @if (errorMessage.Equals(string.Empty) == false)
    {
        <div class="row">
            <div class="text-danger">
                <p class="fw-bolder">
                    @errorMessage;
                </p>
            </div>
        </div>
    }
</EditForm>

@if (designResults is not null && displayOutput)
{
    <section class="container-fluid">
        <h4>Design Outputs:</h4>
        <div class="row row-cols-4">
            <div class="col">
                <p>
                    Name =
                </p>
            </div>
            <div class="col">
                <p>
                    @designResults.Name
                </p>
            </div>
        </div>
        <div class="row row-cols-4">
            <div class="col">
                <p>
                    Voltage Rating =
                </p>
            </div>
            <div class="col">
                <p>
                    @designResults.VoltageRating
                </p>
            </div>
        </div>
        <div class="row row-cols-4">
            <div class="col">
                <p>
                    Current Rating =
                </p>
            </div>
            <div class="col">
                <p>
                    @designResults.CurrentRating
                </p>
            </div>
        </div>
        <div class="row row-cols-4">
            <div class="col">
                <p>
                    Weight =
                </p>
            </div>
            <div class="col">
                <p>
                    @designResults.Weight
                </p>
            </div>
        </div>
        <div class="row row-cols-4">
            <div class="col">
                <p>
                    Power To Weight Ratio =
                </p>
            </div>
            <div class="col">
                <p>
                    @designResults.PowerToWeightRatio
                </p>
            </div>
        </div>
    </section>
}

@code {
    bool displayOutput = false;
    CreateInverterModel model = new();
    string errorMessage = string.Empty;
    InverterDto designResults = new();

    protected async override Task OnInitializedAsync()
    {
    }

    private async Task OnValidSubmit()
    {
        try
        {
            var result = await InverterEndpoints.CreateInverterAsync(model);

            if (result is null)
            {
                throw new Exception("No data returned from the server.");
            }

            if (result is not null && result.IsFailed)
            {
                throw new Exception("Could not calculate design parameters.");
            }

            designResults = result!.Value;
            displayOutput = true;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }


}
