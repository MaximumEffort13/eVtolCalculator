<PageTitle>Detail Design</PageTitle>
<h4>Detail Design</h4>

<section class="container-fluid">
    <Card Style="height:30rem;">
        <img class="rounded-top" src="/Images/Detail_design.webp" alt="Detail Design" width="100%" height="100%"/>
        <CardBody>

        </CardBody>
    </Card>
</section>
<div class="row">
    <br />
</div>
<section class="container-fluid">
    <EditForm Model="@model" OnValidSubmit="@OnValidSubmit">
    <DataAnnotationsValidator />
    <div class="container-fluid">
        <div class="row row-cols-4">
            <div class="col">
                <div class="form-group row g-3">
                    <div class="form-floating mb-3">
                        <InputText id="detail-design-name" class="form-control" @bind-Value="model.Name" placeholder="Project Zero" />
                        <ValidationMessage For=@(() => model.Name) />
                        <label for="detail-design-name">Name</label>
                    </div>
                </div>
            </div>
        </div>
        <div class="row row-cols-4">
            <div class="col">
                <div class="form-floating mb-3">
                    <InputSelect id="blade" class="form-select form-select-sm" @bind-Value="model.BladeId">
                        <option value="" selected>Select</option>
                        @foreach (var blade in Blades)
                        {
                            <option value="@blade.Id">@blade.Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For=@(() => model.BladeId) />
                    <label for="blade" class="col-md-2 col-form-label">Blade</label>
                </div>
            </div>
            <div class="col">
                <div class="form-floating mb-3">
                    <InputSelect id="motor" class="form-select form-select-sm" @bind-Value="model.MotorId">
                        <option value="" selected>Select</option>
                        @foreach (var motor in Motors)
                        {
                            <option value="@motor.Id">@motor.Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For=@(() => model.MotorId) />
                    <label for="motor" class="col-md-2 col-form-label">Motor</label>
                </div>
            </div>
            <div class="col">
                <div class="form-floating mb-3">
                    <InputSelect id="inverter" class="form-select form-select-sm" @bind-Value="model.InverterId">
                        <option value="" selected>Select</option>
                        @foreach (var inverter in Inverters)
                        {
                            <option value="@inverter.Id">@inverter.Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For=@(() => model.InverterId) />
                    <label for="inverter" class="col-md-2 col-form-label">Inverter</label>
                </div>
            </div>
            <div class="col">
                <div class="form-floating mb-3">
                    <InputSelect id="batteryPack" class="form-select form-select-sm" @bind-Value="model.BatteryPackId">
                        <option value="" selected>Select</option>
                        @foreach (var battery in BatteryPacks)
                        {
                            <option value="@battery.Id">@battery.Name</option>
                        }
                    </InputSelect>
                    <ValidationMessage For=@(() => model.BatteryPackId) />
                    <label for="batteryPack" class="col-md-2 col-form-label">Battery Pack</label>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid">
        <div class="row row-cols-4">
            <div class="col">
                <div class="form-floating mb-3">
                    <InputNumber id="missionStruct" class="form-control" @bind-Value="model.MissionParameters.TotalStructureWeight_kg" placeholder="400" />
                    <ValidationMessage For=@(() => model.MissionParameters.TotalStructureWeight_kg) />
                    <label for="missionStruct">Total Structure Weight</label>
                </div>
            </div>
            <div class="col">
                <div class="form-floating mb-3">
                    <InputNumber id="missionPayload" class="form-control" @bind-Value="model.MissionParameters.PayloadWeight_kg" placeholder="100" />
                    <ValidationMessage For=@(() => model.MissionParameters.PayloadWeight_kg) />
                    <label for="missionPayload">Payload Weight</label>
                </div>
            </div>
            <div class="col">
                <div class="form-floating mb-3">
                    <InputNumber id="missionFlightTime" class="form-control" @bind-Value="model.MissionParameters.FlightTimeInMinutes" placeholder="12" />
                    <ValidationMessage For=@(() => model.MissionParameters.FlightTimeInMinutes) />
                    <label for="missionFlightTime">Flight time: (min)</label>
                </div>
            </div>
            <div class="col">
                <div class="form-floating mb-3">
                    <InputNumber id="fuselage" class="form-control" @bind-Value="model.Fuselage.Weight_kg" placeholder="400" />
                    <ValidationMessage For=@(() => model.Fuselage.Weight_kg) />
                    <label for="fuselage">Fuselage Weight: (kg)</label>
                </div>
            </div>
        </div>
        <div class="row row-col-2">
            <div class="col">
                <div class="form-floating mb-3">
                    <InputNumber id="motorQuantity" class="form-control" @bind-Value="model.MotorQuantity" placeholder="4" />
                    <ValidationMessage For=@(() => model.MotorQuantity) />
                    <label for="motorQuantity">Motor Qty: </label>
                </div>
            </div>
            <div class="col">
                <div class="form-floating mb-3">
                    <InputNumber id="bladeQuantity" class="form-control" @bind-Value="model.BladePerMotorQuantity" placeholder="4" />
                    <ValidationMessage For=@(() => model.BladePerMotorQuantity) />
                    <label for="bladeQuantity">Blade Per Motor Qty: </label>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <Button Type="ButtonType.Submit" Color="ButtonColor.Dark" Outline="true">Submit</Button>
    </div>
    @if (errorMessage.Equals(string.Empty) == false)
    {
        <div class="row">
            <div class="text-danger">
                <p class="fw-bolder">
                    @errorMessage;
                </p>
            </div>
        </div>
    }
    </EditForm>
</section>

