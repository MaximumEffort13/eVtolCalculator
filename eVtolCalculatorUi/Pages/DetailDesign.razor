@code {
    [Inject] protected PreloadService PreloadService { get; set; }

    bool displayOutput = true;
    CreateDetailedDesign model = new ();
    string errorMessage = string.Empty;
    ElectricVtolDesignDto designResults { get; set; }

    List<MotorDto> Motors = new();
    List<BladeDto> Blades = new();
    List<InverterDto> Inverters = new();
    List<BatteryPackDto> BatteryPacks = new();
    List<ElectricVtolDesignDto> DetailDesigns = new();

    protected async override Task OnInitializedAsync()
    {
        try
        {
            var state = await AuthState.GetAuthenticationStateAsync();
            if (state is not null && state.User is not null && state.User.Identity.IsAuthenticated is false)
            {
                await AuthService.RefreshAsync();
            }

            PreloadService.Show(SpinnerColor.Warning);

            model.MissionParameters = new();
            model.Fuselage = new();

            var motorResults = await MotorEndpoints.GetMotors();
            if (motorResults.IsFailed)
            {
                errorMessage = motorResults.Reasons.Last().Message;
            }
            else
            {
                Motors = motorResults.Value;
            }

            var inverterResults = await InverterEndpoints.GetInverters();

            if (inverterResults.IsFailed)
            {
                errorMessage = inverterResults.Reasons.Last().Message;
            }
            else
            {
                Inverters = inverterResults.Value;
            }

            var bladeResults = await BladeEndpoints.GetBlades();

            if (bladeResults.IsFailed)
            {
                errorMessage = bladeResults.Reasons.Last().Message;
            }
            else
            {
                Blades = bladeResults.Value;
            }

            var batteryPackResults = await BatteryPackEndpoints.GetBatteries();

            if (batteryPackResults.IsFailed)
            {
                errorMessage = batteryPackResults.Reasons.Last().Message;
            }
            else
            {
                BatteryPacks = batteryPackResults.Value;
            }

            var detailDesigns = await DetailDesignEndpoints.GetAllDetailDesigns();

            if (detailDesigns.IsFailed)
            {
                errorMessage = detailDesigns.Reasons.Last().Message;
            }
            else
            {
                DetailDesigns = detailDesigns.Value;
            }
        }
        catch(Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            StateHasChanged();
            PreloadService.Hide();
        }
    }

    protected Task OnInverterChange(string selectedInverterId)
    {
        if (selectedInverterId == null || selectedInverterId.Equals(string.Empty))
        {
            errorMessage = "Please select a valid inverter.";
            return Task.CompletedTask;
        }

        model.InverterId = selectedInverterId;
        return Task.CompletedTask;
    }

    protected Task OnMotorChange(string selectedMotorId)
    {
        if (selectedMotorId == null || selectedMotorId.Equals("Select"))
        {
            errorMessage = "Please select a valid motor.";
            return Task.CompletedTask;
        }
        model.MotorId = selectedMotorId;
        return Task.CompletedTask;

    }

    protected Task OnBladeChange(string selectedBladeId)
    {
        if (selectedBladeId == null || selectedBladeId.Equals("Select"))
        {
            errorMessage = "Please select a valid blade.";
            return Task.CompletedTask;
        }
        model.BladeId = selectedBladeId;
        return Task.CompletedTask;

    }

    protected Task OnBatteryPackChange(string selectedBatteryPackId)
    {
        if (selectedBatteryPackId == null || selectedBatteryPackId.Equals("Select"))
        {
            errorMessage = "Please select a valid battery pack.";
            return Task.CompletedTask;
        }
        model.BatteryPackId = selectedBatteryPackId;
        return Task.CompletedTask;

    }

    protected async Task OnDetailDesignChange(ChangeEventArgs args)
    {
        var value = args.Value.ToString();

        if (string.IsNullOrEmpty(value) || value.Equals("Select"))
        {
            designResults = new();
            displayOutput = false;
            return;
        }
        var result = await DetailDesignEndpoints.GetDetailDesignByIdAsync(value);
        designResults = result.Value;
        displayOutput = true;

        return;
    }

    private async Task OnValidSubmit()
    {
        errorMessage = string.Empty;
        displayOutput = false;
        designResults = new();

        try
        {
            PreloadService.Show(SpinnerColor.Warning);

            var result = await DetailDesignEndpoints.CreateElectricVtolDesign(model);

            if (result is null)
            {
                throw new Exception("No data returned from the server.");
            }

            if (result is not null && result.IsFailed)
            {
                throw new Exception("Could not calculate design parameters.");
            }

            designResults = result!.Value;
            displayOutput = true;
            DetailDesigns.Add(designResults);

        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            StateHasChanged();
            PreloadService.Hide();
        }
    }
}
