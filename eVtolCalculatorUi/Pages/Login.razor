@page "/login"
@using ApiClient.DataTransferObjects.IdentityObjects;
@inject IAuthenticationService AuthService
@inject NavigationManager NavManager
@attribute [AllowAnonymous]

<PageTitle>Login</PageTitle>

<h3>Login</h3>

<EditForm Model="@model">
    <DataAnnotationsValidator />
    <div class="container-fluid">
        <h4>User Details: </h4>
        <div class="row row-cols-2">
            <div class="col g-3">
                <div class="form-floating mb-3">
                    <InputText id="email" class="form-control" @bind-Value="model.UserName" placeholder="Email Address" />
                    <ValidationMessage For=@(() => model.UserName) />
                    <label for="email">Email</label>
                </div>
            </div>
            <div class="col g-3">
                <div class="form-floating mb-3">
                    <label for="password" class="visually-hidden">Password</label>
                    <InputText type="password" id="password" class="form-control" @bind-Value="model.Password" placeholder="Password" />
                    <ValidationMessage For=@(() => model.Password) />
                </div>
            </div>
        </div>
        <div class="form-group row">

            <div class="col-auto">
                <button type="submit" class="btn btn-success" @onclick="ExecuteLogin">Log In</button>
            </div>
            <div class="col-auto">
                <button type="button" class="btn btn-primary bi bi-person" @onclick="RegisterUser">Register</button>
            </div>
        </div>
    </div>

    @if (showAuthenticationError)
    {
        <div class="form-row">
            <div class="text-danger">
                @authenticationErrorText;
            </div>
        </div>
    }
</EditForm>


@code {
    private AuthenticationUserModel model = new();

    private bool showAuthenticationError;
    private string authenticationErrorText = string.Empty;

    private void RegisterUser()
    {
        NavManager.NavigateTo("/register");
    }

    private async Task ExecuteLogin()
    {
        showAuthenticationError = false;

       AuthenticatedUserModel result = await AuthService.Login(model);

        if (result is null)
        {
            authenticationErrorText = "There was a error while trying to authenticate you.";
            showAuthenticationError = true;
            return;
        }

        NavManager.NavigateTo("/");
    }
}
